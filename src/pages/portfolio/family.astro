---
import Contact from "@components/Contact/Contact.astro";
import PortfolioGrid from "@components/Portfolio/PortfolioGrid.astro";
import TestimonialQuote from "@components/Testimonials/TestimonialQuote.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const portfolios = await getCollection("portfolios", ({ data }) => {
	return data.draft !== true && data.category === "family";
});

const sorted = portfolios.sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
	title="Family & Newborn Portfolio"
	description="Family and newborn photography portfolio by Brook Rose Photography."
>
	<div class="site-container pt-24 md:pt-36">
		<div class="mx-auto max-w-6xl text-center">
			<h1 class="h2 text-pretty uppercase">
				Relaxed, natural family & newborn photography
			</h1>
		</div>
		<PortfolioGrid portfolios={sorted} />
	</div>

	<TestimonialQuote
		quote="Oh Brook, they’re incredible!! Thank you so much, we adore them! We’ll treasure them forever."
		attribution={null}
		uppercase={false}
	/>

	<Contact class="mt-12" />
</BaseLayout>
