---
import weddingImageTwo from "@assets/images/wedding-photos/islington-town-hall/islington-town-hall-wedding-ceremony-with-reception-at-bourne-amp-hollingworth_38.jpg";
import weddingImageOne from "@assets/images/wedding-photos/north-mymms-mansion-house.png";
import weddingImageThree from "@assets/images/wedding-photos/north-mymms-mansion-house-signing-papers.png";
import ServiceLanding from "@components/SeoLanding/ServiceLanding.astro";
---

<ServiceLanding
	title="Wedding Photographer in Chichester, London & UK | Brook Rose Photography"
	description="Natural documentary wedding photography in Chichester, London, West Sussex, and across the UK. View wedding stories, pricing, and availability."
	kicker="Chichester Wedding Photographer"
	heading="Documentary wedding photography in Chichester, London, and beyond"
	intro="Relaxed, romantic wedding photography for couples getting married in Chichester, London, across West Sussex, and further afield. Brook Rose Photography captures the atmosphere, people, and fleeting moments that make the day feel like yours."
	primaryCta={{ label: "View wedding pricing", href: "/pricing/weddings/" }}
	secondaryCta={{ label: "See wedding portfolio", href: "/portfolio/weddings/" }}
	highlights={[
		"Natural coverage for Chichester weddings, London ceremonies, countryside venues, and intimate celebrations.",
		"Documentary-led photography with gentle direction for portraits when you need it.",
		"Half day, full day, and bespoke wedding collections for celebrations across the UK.",
	]}
	images={[
		{
			src: weddingImageOne,
			alt: "Bride and groom outside North Mymms Mansion House after their wedding ceremony",
		},
		{
			src: weddingImageTwo,
			alt: "Documentary wedding moment during an Islington Town Hall celebration",
		},
		{
			src: weddingImageThree,
			alt: "Couple signing wedding papers during a North Mymms Mansion House ceremony",
		},
	]}
	sections={[
		{
			heading: "A calm, story-led approach to your wedding day",
			body: [
				"Your wedding photographs should feel honest rather than staged. The focus is on real connection, quiet in-between moments, family emotion, details you chose carefully, and portraits that still feel like you.",
				"Coverage can include morning preparations, ceremony, confetti, couple portraits, speeches, reception details, first dance, and the late-evening moments that often become favourites.",
			],
		},
		{
			heading: "Chichester, London, West Sussex, and UK weddings",
			body: [
				"Based around Chichester, Brook Rose Photography is well placed for weddings across West Sussex, the South Coast, London town halls, city celebrations, country houses, registry offices, garden celebrations, and destination venues.",
				"If your plans are outside West Sussex, including London or elsewhere in the UK, bespoke coverage can be shaped around your timings, travel, and the parts of the day that matter most to you.",
			],
		},
	]}
	relatedLinks={[
		{ label: "Wedding pricing", href: "/pricing/weddings/" },
		{ label: "Wedding portfolio", href: "/portfolio/weddings/" },
		{ label: "Full gallery", href: "/gallery/" },
	]}
	faqs={[
		{
			question: "Do you photograph weddings outside Chichester?",
			answer:
				"Yes. Weddings are covered across West Sussex, London, the wider UK, and destination locations. Travel can be included in a bespoke quote depending on the location and schedule.",
		},
		{
			question: "Can we book you for a London wedding?",
			answer:
				"Yes. London weddings, registry office ceremonies, town hall weddings, and city celebrations are welcome. Share your venue, schedule, and coverage needs when you enquire.",
		},
		{
			question: "Can we book half day wedding coverage?",
			answer:
				"Yes. Half day coverage works well for shorter ceremonies, intimate weddings, and couples who want the key moments captured without full-day photography.",
		},
		{
			question: "Do you help with portraits on the day?",
			answer:
				"Yes. The style is relaxed and documentary-led, but gentle direction is available for couple portraits, family groups, and moments where a little structure helps.",
		},
	]}
/>
