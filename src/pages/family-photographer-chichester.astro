---
import familyImageOne from "@assets/images/family-images/familyphotography_0.jpg";
import familyImageThree from "@assets/images/family-images/familyphotography_6.jpg";
import familyImageTwo from "@assets/images/family-images/familyphotography_10.jpeg";
import ServiceLanding from "@components/SeoLanding/ServiceLanding.astro";
---

<ServiceLanding
	title="Family Photographer in Chichester | Brook Rose Photography"
	description="Relaxed family photography in Chichester and West Sussex. Natural outdoor and at-home sessions for families, motherhood, children, and milestones."
	kicker="Chichester Family Photographer"
	heading="Natural family photography in Chichester"
	intro="Relaxed family photography for parents who want honest, warm images without stiff posing. Sessions can take place at home, outdoors, or somewhere meaningful around Chichester and West Sussex."
	primaryCta={{ label: "View family pricing", href: "/pricing/family-newborn/" }}
	secondaryCta={{ label: "See family portfolio", href: "/portfolio/family/" }}
	highlights={[
		"At-home and outdoor family sessions across Chichester and West Sussex.",
		"Easy-going photography for babies, children, parents, and extended family.",
		"Natural prompts and gentle direction so the session feels relaxed rather than formal.",
	]}
	images={[
		{
			src: familyImageOne,
			alt: "Natural family photography session outdoors in West Sussex",
		},
		{
			src: familyImageTwo,
			alt: "Relaxed family portrait session with children",
		},
		{
			src: familyImageThree,
			alt: "Documentary family photography moment in natural light",
		},
	]}
	sections={[
		{
			heading: "Family photographs with room for real life",
			body: [
				"Family sessions are built around connection, movement, play, and the small details you want to remember. The aim is to make space for your children to be themselves rather than forcing everyone into fixed poses.",
				"Sessions can suit new parents, growing families, birthdays, maternity moments, seasonal portraits, and milestone updates when you want photographs that feel softer and more personal.",
			],
		},
		{
			heading: "Local sessions around Chichester",
			body: [
				"Chichester and the surrounding West Sussex area offer beautiful settings for relaxed portraits, from home-based sessions to gardens, beaches, parks, woodland, and favourite family places.",
				"Before the session, you can talk through timings, location ideas, outfits, and what your children usually respond to so the shoot feels manageable from the start.",
			],
		},
	]}
	relatedLinks={[
		{ label: "Family pricing", href: "/pricing/family-newborn/" },
		{ label: "Family portfolio", href: "/portfolio/family/" },
		{ label: "Full gallery", href: "/gallery/" },
	]}
	faqs={[
		{
			question: "Where can a family photoshoot take place?",
			answer:
				"Sessions can happen at home, outdoors, or at a meaningful location around Chichester and West Sussex. The best setting is usually somewhere your family can relax naturally.",
		},
		{
			question: "What if my children do not sit still?",
			answer:
				"They do not need to. The session is designed around movement, connection, and gentle prompts, so energetic children can still be photographed naturally.",
		},
		{
			question: "Can we include grandparents or extended family?",
			answer:
				"Yes. Family sessions can include extended family, though larger groups may need a little more planning so there is enough time for different combinations.",
		},
	]}
/>
