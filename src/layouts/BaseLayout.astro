---
import "@/styles/global.css";

import Footer from "@components/Footer/Footer.astro";
import Nav from "@components/Nav/Nav.astro";
import BaseHead from "@layouts/BaseHead.astro";
import Analytics from "@vercel/analytics/astro";

// heroImage and authorData are defined on blog posts
// authorData could also be defined on the about author page
interface Props {
	type?: "general";
	navStartStyle?: "default" | "white";
	title: string;
	description: string;
	heroImage?: ImageMetadata;
	noindex?: boolean; // you need to opt-in to no indexing, as it hides the page from search engines
}

const {
	type = "general",
	navStartStyle = "default",
	title,
	description,
	heroImage,
	noindex = false,
} = Astro.props as Props;
---

<!doctype html>
<html lang="en" transition:animate="fade">
	<head>
		<BaseHead
			type={type}
			title={title}
			description={description}
			image={heroImage ? heroImage : undefined}
			noindex={noindex}
		/>
	</head>
	<body id="body" class="bg-base-50 text-base-900">
		<div class="min-h-[100lvh]">
			<Nav startStyle={navStartStyle} />
			<main>
				<slot />
			</main>
		</div>
		<Footer />
		<Analytics />
	</body>

	<script>
		function initScrollAnimations() {
			// Enable animation CSS only once JS is running — prevents invisible
			// content (opacity:0) appearing as blank gaps on slow devices
			document.documentElement.classList.add("js-anim");

			// Apply stagger delays to children of [data-animate-stagger] containers
			document.querySelectorAll("[data-animate-stagger]").forEach((container) => {
				Array.from(container.children).forEach((child, i) => {
					(child as HTMLElement).style.transitionDelay = `${i * 110}ms`;
				});
			});

			const observer = new IntersectionObserver(
				(entries) => {
					entries.forEach((entry) => {
						if (entry.isIntersecting) {
							entry.target.classList.add("is-visible");
							observer.unobserve(entry.target);
						}
					});
				},
				{ threshold: 0.08, rootMargin: "0px 0px -40px 0px" },
			);

			document
				.querySelectorAll("[data-animate], [data-animate-stagger] > *")
				.forEach((el) => observer.observe(el));
		}

		function initMotionAccordions() {
			const animationDuration = 320;
			const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");

			document.querySelectorAll<HTMLDetailsElement>("[data-motion-accordion]").forEach((accordion) => {
				if (accordion.dataset.accordionReady === "true") {
					return;
				}

				const summary = accordion.querySelector("summary");
				const panel = accordion.querySelector<HTMLElement>("[data-accordion-panel]");

				if (!summary || !panel) {
					return;
				}

				accordion.dataset.accordionReady = "true";

				const setOpenPanelHeight = () => {
					if (accordion.open) {
						panel.style.height = `${panel.scrollHeight}px`;
					}
				};

				summary.addEventListener("click", (event) => {
					if (prefersReducedMotion.matches) {
						return;
					}

					event.preventDefault();

					if (accordion.dataset.animating === "true") {
						return;
					}

					accordion.dataset.animating = "true";

					if (accordion.open) {
						accordion.dataset.closing = "true";
						panel.style.height = `${panel.scrollHeight}px`;

						requestAnimationFrame(() => {
							panel.style.height = "0px";
						});

						window.setTimeout(() => {
							accordion.open = false;
							delete accordion.dataset.closing;
							delete accordion.dataset.animating;
						}, animationDuration);

						return;
					}

					accordion.open = true;
					panel.style.height = "0px";

					requestAnimationFrame(() => {
						panel.style.height = `${panel.scrollHeight}px`;
					});

					window.setTimeout(() => {
						delete accordion.dataset.animating;
					}, animationDuration);
				});

				panel.addEventListener("transitionend", (event) => {
					if (event.propertyName === "height" && accordion.open) {
						panel.style.height = `${panel.scrollHeight}px`;
					}
				});

				window.addEventListener("resize", setOpenPanelHeight, { passive: true });
			});
		}

		// Run on initial load and after Astro view transitions
		initScrollAnimations();
		initMotionAccordions();
		document.addEventListener("astro:page-load", initScrollAnimations);
		document.addEventListener("astro:page-load", initMotionAccordions);
	</script>
</html>
