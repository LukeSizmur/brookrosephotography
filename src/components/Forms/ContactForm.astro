---
import Button from "@components/Button/Button.astro";
---

<form
	id="contact-form"
	name="contact"
	action="mailto:brook.rose@hotmail.com"
	method="get"
	class="flex h-full flex-col justify-between gap-4"
>
	<div>
		<label for="contact-name" class="font-heading-1 text-lg uppercase">Your Name</label>
		<input
			type="text"
			class="form__input"
			name="name"
			id="contact-name"
			autocomplete="name"
			placeholder=""
			required
		/>
	</div>
	<div class="flex flex-col gap-1">
		<label for="contact-email" class="font-heading-1 text-lg uppercase">Contact E-mail </label>
		<input
			type="email"
			class="form__input"
			name="email"
			id="contact-email"
			autocomplete="email"
			inputmode="email"
			placeholder=""
			required
		/>
	</div>
	<div>
		<label for="contact-date" class="font-heading-1 text-lg uppercase">Event Date </label>
		<input type="date" class="form__input" name="date" id="contact-date" placeholder="" required />
	</div>
	<div>
		<label for="contact-message" class="font-heading-1 text-lg uppercase">Message </label>
		<textarea
			name="message"
			class="form__input"
			id="contact-message"
			rows="6"
			placeholder=""
			required></textarea>
	</div>
	<div class="hidden" aria-hidden="true">
		<label for="contact-website">Website</label>
		<input
			type="text"
			name="website"
			id="contact-website"
			tabindex="-1"
			autocomplete="off"
		/>
	</div>
	<div class="flex">
		<Button variant="primary" type="submit" class="w-full px-10 md:w-fit">Create Email</Button>
	</div>
	<p id="contact-form-status" class="description min-h-[1.6rem]" aria-live="polite"></p>
</form>

<script data-astro-rerun>
	const recipientEmail = "brook.rose@hotmail.com";
	const contactForm = document.querySelector("#contact-form");
	const contactFormStatus = document.querySelector("#contact-form-status");

	if (contactForm instanceof HTMLFormElement && contactFormStatus instanceof HTMLElement) {
		const submitButton = contactForm.querySelector('button[type="submit"]');
		const submitButtonText = submitButton?.querySelector("span");
		const initialButtonText = submitButtonText?.textContent || "Create Email";

		contactForm.addEventListener("submit", async (event) => {
			event.preventDefault();

			if (!(submitButton instanceof HTMLButtonElement)) {
				return;
			}

			submitButton.disabled = true;
			if (submitButtonText) {
				submitButtonText.textContent = "Opening...";
			}
			contactFormStatus.textContent = "";

			try {
				const formData = new FormData(contactForm);
				const name = String(formData.get("name") || "").trim();
				const email = String(formData.get("email") || "").trim();
				const date = String(formData.get("date") || "").trim();
				const message = String(formData.get("message") || "").trim();
				const subject = `Brook Rose Photography enquiry from ${name}`;
				const body = [
					"Hi Brook,",
					"",
					message,
					"",
					"Enquiry details:",
					`Name: ${name}`,
					`Email: ${email}`,
					`Event date: ${date}`,
				].join("\n");
				const mailtoUrl = new URL(`mailto:${recipientEmail}`);

				mailtoUrl.searchParams.set("subject", subject);
				mailtoUrl.searchParams.set("body", body);
				window.location.href = mailtoUrl.toString();
				contactFormStatus.textContent = "Your email app should open with the message ready to send.";
			} catch (error) {
				contactFormStatus.textContent =
					error instanceof Error
						? error.message
						: "Your email app could not be opened. Please email Brook directly.";
			} finally {
				submitButton.disabled = false;
				if (submitButtonText) {
					submitButtonText.textContent = initialButtonText;
				}
			}
		});
	}
</script>
