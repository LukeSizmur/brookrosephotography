---
import Button from "@components/Button/Button.astro";
---

<form
	id="contact-form"
	name="contact"
	action="mailto:brook.rose@hotmail.com"
	method="get"
	class="flex h-full flex-col justify-between gap-4"
>
	<div class="grid gap-4 md:grid-cols-2">
		<div>
			<label for="contact-first-name" class="font-heading-1 text-lg uppercase">First Name</label>
			<input
				type="text"
				class="form__input"
				name="firstName"
				id="contact-first-name"
				autocomplete="given-name"
				placeholder=""
				required
			/>
		</div>
		<div>
			<label for="contact-last-name" class="font-heading-1 text-lg uppercase">Last Name</label>
			<input
				type="text"
				class="form__input"
				name="lastName"
				id="contact-last-name"
				autocomplete="family-name"
				placeholder=""
				required
			/>
		</div>
	</div>
	<div class="flex flex-col gap-1">
		<label for="contact-email" class="font-heading-1 text-lg uppercase">Email Address</label>
		<input
			type="email"
			class="form__input"
			name="email"
			id="contact-email"
			autocomplete="email"
			inputmode="email"
			placeholder=""
			required
		/>
	</div>
	<div>
		<label for="contact-date" class="font-heading-1 text-lg uppercase">Event date</label>
		<input type="date" class="form__input" name="eventDate" id="contact-date" required />
	</div>
	<div>
		<label for="contact-plans" class="font-heading-1 text-lg uppercase">
			Tell me about your wedding plans
		</label>
		<textarea
			name="weddingPlans"
			class="form__input"
			id="contact-plans"
			rows="6"
			placeholder=""
			required></textarea>
	</div>
	<div>
		<label for="contact-number" class="font-heading-1 text-lg uppercase">Contact number</label>
		<p class="description mb-2 text-sm">
			I may send a quick text to confirm I received your enquiry, as emails can land in junk.
		</p>
		<input
			type="tel"
			class="form__input"
			name="contactNumber"
			id="contact-number"
			autocomplete="tel"
			inputmode="tel"
			placeholder=""
			required
		/>
	</div>
	<div>
		<fieldset class="flex flex-col gap-2">
			<legend class="font-heading-1 text-lg uppercase">How did you hear about me?</legend>
			<label class="flex items-center gap-3">
				<input type="radio" name="referralSource" value="Facebook advert" required />
				<span>Facebook advert</span>
			</label>
			<label class="flex items-center gap-3">
				<input type="radio" name="referralSource" value="TikTok" />
				<span>TikTok</span>
			</label>
			<label class="flex items-center gap-3">
				<input type="radio" name="referralSource" value="Recommendation" />
				<span>Recommendation</span>
			</label>
			<label class="flex items-center gap-3">
				<input type="radio" name="referralSource" value="Instagram" />
				<span>Instagram</span>
			</label>
			<label class="flex items-center gap-3">
				<input type="radio" name="referralSource" value="Other" />
				<span>Other</span>
			</label>
		</fieldset>
	</div>
	<div>
		<label for="contact-budget" class="font-heading-1 text-lg uppercase">Photography budget</label>
		<input
			type="text"
			class="form__input"
			name="photographyBudget"
			id="contact-budget"
			placeholder=""
		/>
	</div>
	<div class="hidden" aria-hidden="true">
		<label for="contact-website">Website</label>
		<input
			type="text"
			name="website"
			id="contact-website"
			tabindex="-1"
			autocomplete="off"
		/>
	</div>
	<div class="flex">
		<Button variant="primary" type="submit" class="w-full px-10 md:w-fit">Submit</Button>
	</div>
	<p id="contact-form-status" class="contact-form-status description min-h-[1.6rem]" aria-live="polite"></p>
</form>

<style>
	#contact-form label,
	#contact-form legend {
		transition: color var(--motion-duration-base) var(--motion-ease-out);
	}

	#contact-form input:focus + span,
	#contact-form label:has(+ .form__input:focus),
	#contact-form div:focus-within > label,
	#contact-form div:focus-within > fieldset legend {
		color: var(--color-primary-700);
	}

	.contact-form-status {
		opacity: 0;
		transform: translateY(6px);
		transition:
			opacity var(--motion-duration-base) var(--motion-ease-out),
			transform var(--motion-duration-base) var(--motion-ease-out);
	}

	.contact-form-status.is-visible {
		opacity: 1;
		transform: translateY(0);
	}

	#contact-form button[type="submit"][data-loading="true"] {
		transform: translateY(0);
	}

	#contact-form button[type="submit"][data-loading="true"] span::after {
		content: "";
		display: inline-block;
		width: 0.35em;
		height: 0.35em;
		margin-left: 0.45em;
		border-radius: 999px;
		background: currentColor;
		animation: contactSubmitPulse 900ms var(--motion-ease-out) infinite;
		vertical-align: middle;
	}

	@keyframes contactSubmitPulse {
		0%,
		100% {
			opacity: 0.35;
			transform: scale(0.72);
		}

		50% {
			opacity: 1;
			transform: scale(1);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		#contact-form label,
		#contact-form legend,
		.contact-form-status {
			transition: none;
			transform: none;
		}

		#contact-form button[type="submit"][data-loading="true"] span::after {
			animation: none;
		}
	}
</style>

<script data-astro-rerun>
	const recipientEmail = "brook.rose@hotmail.com";
	const contactForm = document.querySelector("#contact-form");
	const contactFormStatus = document.querySelector("#contact-form-status");

	if (contactForm instanceof HTMLFormElement && contactFormStatus instanceof HTMLElement) {
		const submitButton = contactForm.querySelector('button[type="submit"]');
		const submitButtonText = submitButton?.querySelector("span");
		const initialButtonText = submitButtonText?.textContent || "Submit";
		const setStatus = (message: string) => {
			contactFormStatus.classList.toggle("is-visible", message.length > 0);
			contactFormStatus.textContent = message;
		};

		contactForm.addEventListener("submit", async (event) => {
			event.preventDefault();

			if (!(submitButton instanceof HTMLButtonElement)) {
				return;
			}

			submitButton.disabled = true;
			submitButton.dataset.loading = "true";
			if (submitButtonText) {
				submitButtonText.textContent = "Opening...";
			}
			setStatus("");

			try {
				const formData = new FormData(contactForm);
				const firstName = String(formData.get("firstName") || "").trim();
				const lastName = String(formData.get("lastName") || "").trim();
				const name = `${firstName} ${lastName}`.trim();
				const email = String(formData.get("email") || "").trim();
				const weddingDate = String(formData.get("eventDate") || "").trim();
				const weddingPlans = String(formData.get("weddingPlans") || "").trim();
				const contactNumber = String(formData.get("contactNumber") || "").trim();
				const referralSource = String(formData.get("referralSource") || "").trim();
				const photographyBudget = String(formData.get("photographyBudget") || "").trim();
				const subject = `Brook Rose Photography enquiry from ${name}`;
				const body = [
					"Hi Brook,",
					"",
					weddingPlans,
					"",
					"Enquiry details:",
					`First name: ${firstName}`,
					`Last name: ${lastName}`,
					`Email: ${email}`,
					`Contact number: ${contactNumber}`,
					`Wedding date: ${weddingDate}`,
					`How they heard of Brook Rose Photography: ${referralSource}`,
					`Photography budget: ${photographyBudget || "Not provided"}`,
				].join("\n");
				const mailtoUrl = `mailto:${recipientEmail}?subject=${encodeURIComponent(
					subject,
				)}&body=${encodeURIComponent(body)}`;

				window.location.href = mailtoUrl;
				setStatus("Your email app should open with the message ready to send.");
			} catch (error) {
				setStatus(
					error instanceof Error
						? error.message
						: "Your email app could not be opened. Please email Brook directly.",
				);
			} finally {
				submitButton.disabled = false;
				delete submitButton.dataset.loading;
				if (submitButtonText) {
					submitButtonText.textContent = initialButtonText;
				}
			}
		});
	}
</script>
