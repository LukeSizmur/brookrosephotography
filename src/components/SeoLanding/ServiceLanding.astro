---
import Button from "@components/Button/Button.astro";
import Contact from "@components/Contact/Contact.astro";
import TestimonialQuote from "@components/Testimonials/TestimonialQuote.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";

interface LinkItem {
	label: string;
	href: string;
}

interface FaqItem {
	question: string;
	answer: string;
}

interface ServiceImage {
	src: ImageMetadata;
	alt: string;
}

interface Props {
	title: string;
	description: string;
	kicker: string;
	heading: string;
	intro: string;
	primaryCta: LinkItem;
	secondaryCta: LinkItem;
	sections: {
		heading: string;
		body: string[];
	}[];
	highlights: string[];
	images: ServiceImage[];
	relatedLinks: LinkItem[];
	faqs: FaqItem[];
}

const {
	title,
	description,
	kicker,
	heading,
	intro,
	primaryCta,
	secondaryCta,
	sections,
	highlights,
	images,
	relatedLinks,
	faqs,
} = Astro.props as Props;
---

<BaseLayout title={title} description={description}>
	<main>
		<section class="site-container pt-24 pb-12 md:pt-36 md:pb-16">
			<div class="mx-auto max-w-4xl text-center">
				<p class="mb-4 text-sm tracking-[0.28em] text-primary-500 uppercase">{kicker}</p>
				<h1 class="h1 text-pretty uppercase">{heading}</h1>
				<p class="description mx-auto mt-6 max-w-2xl text-lg leading-relaxed">{intro}</p>
				<div class="mt-8 flex flex-col justify-center gap-4 sm:flex-row">
					<Button href={primaryCta.href} arrow="right">{primaryCta.label}</Button>
					<Button href={secondaryCta.href} variant="outline">{secondaryCta.label}</Button>
				</div>
			</div>
		</section>

		<section class="site-container pb-16">
			<div class="grid gap-4 md:grid-cols-3">
				{
					images.map((image, index) => (
						<div class:list={["overflow-hidden", index === 1 ? "md:mt-10" : ""]}>
							<Image
								src={image.src}
								alt={image.alt}
								width={720}
								height={index === 1 ? 860 : 680}
								densities={[1.5, 2]}
								class="h-full min-h-80 w-full object-cover"
								loading={index === 0 ? "eager" : "lazy"}
								quality="high"
							/>
						</div>
					))
				}
			</div>
		</section>

		<section class="site-container pb-16">
			<div class="grid gap-6 md:grid-cols-3">
				{
					highlights.map((highlight) => (
						<div class="border border-primary-200 bg-base-50/60 p-6">
							<p class="font-heading-1 text-xl leading-snug text-primary-700">{highlight}</p>
						</div>
					))
				}
			</div>
		</section>

		<section class="site-container pb-16 md:pb-24">
			<div class="mx-auto grid max-w-6xl gap-10 lg:grid-cols-[0.9fr_1.1fr]">
				<div>
					<p class="mb-3 text-sm tracking-[0.25em] text-primary-500 uppercase">Approach</p>
					<h2 class="h2 text-pretty">Photography that feels natural, personal, and true to you.</h2>
				</div>
				<div class="space-y-10">
					{
						sections.map((section) => (
							<section>
								<h2 class="font-heading-1 text-3xl leading-tight text-primary-700">
									{section.heading}
								</h2>
								<div class="mt-4 space-y-4 text-base leading-relaxed text-base-700 md:text-lg">
									{section.body.map((paragraph) => <p>{paragraph}</p>)}
								</div>
							</section>
						))
					}
				</div>
			</div>
		</section>

		<section class="site-container pb-16 md:pb-24">
			<div class="mx-auto max-w-5xl border-y border-primary-200 py-10">
				<h2 class="font-heading-1 text-3xl text-primary-700">Useful next steps</h2>
				<div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
					{
						relatedLinks.map((link) => (
							<a
								href={link.href}
								class="group flex items-center justify-between gap-4 border border-primary-200 px-5 py-4 text-sm tracking-widest text-base-700 uppercase transition-colors hover:border-primary-500 hover:text-primary-700"
							>
								<span>{link.label}</span>
								<Icon
									name="mynaui/arrow-long-right"
									class="h-[1.4em] w-[1.4em] shrink-0 transition-transform group-hover:translate-x-1"
									aria-hidden="true"
								/>
							</a>
						))
					}
				</div>
			</div>
		</section>

		<section class="site-container pb-12 md:pb-20">
			<div class="mx-auto max-w-4xl">
				<p class="mb-3 text-sm tracking-[0.25em] text-primary-500 uppercase">Questions</p>
				<h2 class="h2 text-pretty">Frequently asked questions</h2>
				<div class="mt-8 divide-y divide-primary-200 border-y border-primary-200">
					{
						faqs.map((faq) => (
							<details class="service-accordion">
								<summary class="flex cursor-pointer list-none items-center justify-between gap-6 py-6 font-heading-1 text-xl leading-snug text-primary-700 transition-colors duration-200 hover:text-primary-900">
									<span class="pr-4">{faq.question}</span>
									<span class="accordion-icon" aria-hidden="true">
										<span class="accordion-icon__line"></span>
										<span class="accordion-icon__line accordion-icon__line--vertical"></span>
									</span>
								</summary>
								<div class="accordion-panel">
									<p class="max-w-3xl pb-6 text-base leading-relaxed text-base-700">{faq.answer}</p>
								</div>
							</details>
						))
					}
				</div>
			</div>
		</section>

		<TestimonialQuote />
		<Contact class="mt-12" />
	</main>
</BaseLayout>

<style>
	.service-accordion summary::-webkit-details-marker {
		display: none;
	}

	.accordion-icon {
		position: relative;
		display: inline-grid;
		width: 1rem;
		height: 1rem;
		flex: 0 0 1rem;
		place-items: center;
		color: var(--color-primary-600);
		transition:
			color 180ms cubic-bezier(0.25, 1, 0.5, 1),
			transform 260ms cubic-bezier(0.25, 1, 0.5, 1);
	}

	.service-accordion summary:hover .accordion-icon {
		color: var(--color-primary-800);
	}

	.accordion-icon__line {
		position: absolute;
		width: 1rem;
		height: 1px;
		background: currentColor;
		transition:
			opacity 180ms cubic-bezier(0.25, 1, 0.5, 1),
			transform 280ms cubic-bezier(0.25, 1, 0.5, 1);
	}

	.accordion-icon__line--vertical {
		transform: rotate(90deg);
	}

	.service-accordion[open]:not([data-closing="true"]) .accordion-icon {
		color: var(--color-primary-800);
		transform: rotate(180deg);
	}

	.service-accordion[open]:not([data-closing="true"]) .accordion-icon__line--vertical {
		opacity: 0;
		transform: rotate(90deg) scaleX(0.35);
	}

	.accordion-panel {
		overflow: hidden;
		height: 0;
		opacity: 0;
		transform: translateY(-0.25rem);
		transition:
			height 320ms cubic-bezier(0.25, 1, 0.5, 1),
			opacity 220ms cubic-bezier(0.25, 1, 0.5, 1),
			transform 320ms cubic-bezier(0.25, 1, 0.5, 1);
	}

	.service-accordion[open] .accordion-panel {
		height: auto;
	}

	.service-accordion[open]:not([data-closing="true"]) .accordion-panel {
		opacity: 1;
		transform: translateY(0);
	}

	@media (prefers-reduced-motion: reduce) {
		.accordion-icon,
		.accordion-icon__line,
		.accordion-panel {
			transition: none;
		}
	}
</style>

<script>
	const animationDuration = 320;

	document.querySelectorAll<HTMLDetailsElement>(".service-accordion").forEach((accordion) => {
		const summary = accordion.querySelector("summary");
		const panel = accordion.querySelector<HTMLElement>(".accordion-panel");

		if (!summary || !panel) {
			return;
		}

		const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");

		const setOpenPanelHeight = () => {
			if (accordion.open) {
				panel.style.height = `${panel.scrollHeight}px`;
			}
		};

		summary.addEventListener("click", (event) => {
			if (prefersReducedMotion.matches) {
				return;
			}

			event.preventDefault();

			if (accordion.dataset.animating === "true") {
				return;
			}

			accordion.dataset.animating = "true";

			if (accordion.open) {
				accordion.dataset.closing = "true";
				panel.style.height = `${panel.scrollHeight}px`;

				requestAnimationFrame(() => {
					panel.style.height = "0px";
				});

				window.setTimeout(() => {
					accordion.open = false;
					delete accordion.dataset.closing;
					delete accordion.dataset.animating;
				}, animationDuration);

				return;
			}

			accordion.open = true;
			panel.style.height = "0px";

			requestAnimationFrame(() => {
				panel.style.height = `${panel.scrollHeight}px`;
			});

			window.setTimeout(() => {
				delete accordion.dataset.animating;
			}, animationDuration);
		});

		panel.addEventListener("transitionend", (event) => {
			if (event.propertyName === "height" && accordion.open) {
				panel.style.height = `${panel.scrollHeight}px`;
			}
		});

		window.addEventListener("resize", setOpenPanelHeight);
	});
</script>
