---
import Button from "@components/Button/Button.astro";
import Contact from "@components/Contact/Contact.astro";
import TestimonialQuote from "@components/Testimonials/TestimonialQuote.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";

interface LinkItem {
	label: string;
	href: string;
}

interface FaqItem {
	question: string;
	answer: string;
}

interface ServiceImage {
	src: ImageMetadata;
	alt: string;
}

interface Props {
	title: string;
	description: string;
	kicker: string;
	heading: string;
	intro: string;
	primaryCta: LinkItem;
	secondaryCta: LinkItem;
	sections: {
		heading: string;
		body: string[];
	}[];
	highlights: string[];
	images: ServiceImage[];
	relatedLinks: LinkItem[];
	faqs: FaqItem[];
}

const {
	title,
	description,
	kicker,
	heading,
	intro,
	primaryCta,
	secondaryCta,
	sections,
	highlights,
	images,
	relatedLinks,
	faqs,
} = Astro.props as Props;
---

<BaseLayout title={title} description={description}>
	<main>
		<section class="site-container pt-24 pb-12 md:pt-36 md:pb-16">
			<div class="mx-auto max-w-4xl text-center">
				<p
					class="service-hero-reveal mb-4 text-sm tracking-[0.28em] text-primary-500 uppercase"
					style="--service-enter-delay: 80ms"
				>
					{kicker}
				</p>
				<h1 class="service-hero-reveal h1 text-pretty uppercase" style="--service-enter-delay: 180ms">
					{heading}
				</h1>
				<p
					class="service-hero-reveal description mx-auto mt-6 max-w-2xl text-lg leading-relaxed"
					style="--service-enter-delay: 300ms"
				>
					{intro}
				</p>
				<div
					class="service-hero-reveal mt-8 flex flex-col justify-center gap-4 sm:flex-row"
					style="--service-enter-delay: 420ms"
				>
					<Button href={primaryCta.href} arrow="right">{primaryCta.label}</Button>
					<Button href={secondaryCta.href} variant="outline">{secondaryCta.label}</Button>
				</div>
			</div>
		</section>

		<section class="site-container pb-16">
			<div class="grid gap-4 md:grid-cols-3">
				{
					images.map((image, index) => (
						<div
							class:list={[
								"service-image-reveal service-image-frame overflow-hidden",
								index === 1 ? "md:mt-10" : "",
							]}
							style={`--service-enter-delay: ${520 + index * 120}ms`}
						>
							<Image
								src={image.src}
								alt={image.alt}
								width={720}
								height={index === 1 ? 860 : 680}
								densities={[1.5, 2]}
								class="service-image h-full min-h-80 w-full object-cover"
								loading={index === 0 ? "eager" : "lazy"}
								quality="high"
							/>
						</div>
					))
				}
			</div>
		</section>

		<section class="site-container pb-16">
			<div class="grid gap-6 md:grid-cols-3" data-animate-stagger>
				{
					highlights.map((highlight) => (
						<div class="service-highlight-card border border-primary-200 bg-base-50/60 p-6">
							<p class="font-heading-1 text-xl leading-snug text-primary-700">{highlight}</p>
						</div>
					))
				}
			</div>
		</section>

		<section class="site-container pb-16 md:pb-24">
			<div class="mx-auto grid max-w-6xl gap-10 lg:grid-cols-[0.9fr_1.1fr]">
				<div data-animate="from-left">
					<p class="mb-3 text-sm tracking-[0.25em] text-primary-500 uppercase">Approach</p>
					<h2 class="h2 text-pretty">Photography that feels natural, personal, and true to you.</h2>
				</div>
				<div class="space-y-10" data-animate-stagger>
					{
						sections.map((section) => (
							<section class="service-copy-block">
								<h2 class="font-heading-1 text-3xl leading-tight text-primary-700">
									{section.heading}
								</h2>
								<div class="mt-4 space-y-4 text-base leading-relaxed text-base-700 md:text-lg">
									{section.body.map((paragraph) => <p>{paragraph}</p>)}
								</div>
							</section>
						))
					}
				</div>
			</div>
		</section>

		<section class="site-container pb-16 md:pb-24">
			<div class="mx-auto max-w-5xl border-y border-primary-200 py-10" data-animate>
				<h2 class="font-heading-1 text-3xl text-primary-700">Useful next steps</h2>
				<div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3" data-animate-stagger>
					{
						relatedLinks.map((link) => (
							<a
								href={link.href}
								class="service-next-link group flex items-center justify-between gap-4 border border-primary-200 px-5 py-4 text-sm tracking-widest text-base-700 uppercase transition-colors hover:border-primary-500 hover:text-primary-700"
							>
								<span>{link.label}</span>
								<Icon
									name="mynaui/arrow-long-right"
									class="h-[1.4em] w-[1.4em] shrink-0 transition-transform group-hover:translate-x-1"
									aria-hidden="true"
								/>
							</a>
						))
					}
				</div>
			</div>
		</section>

		<section class="site-container pb-12 md:pb-20">
			<div class="mx-auto max-w-4xl">
				<p class="mb-3 text-sm tracking-[0.25em] text-primary-500 uppercase" data-animate>
					Questions
				</p>
				<h2 class="h2 text-pretty" data-animate style="--animate-delay: 90ms">
					Frequently asked questions
				</h2>
				<div class="mt-8 divide-y divide-primary-200 border-y border-primary-200" data-animate-stagger>
					{
						faqs.map((faq) => (
							<details class="service-accordion" data-motion-accordion>
								<summary class="flex cursor-pointer list-none items-center justify-between gap-6 py-6 font-heading-1 text-xl leading-snug text-primary-700 transition-colors duration-200 hover:text-primary-900">
									<span class="pr-4">{faq.question}</span>
									<span class="accordion-icon" aria-hidden="true">
										<span class="accordion-icon__line"></span>
										<span class="accordion-icon__line accordion-icon__line--vertical"></span>
									</span>
								</summary>
								<div class="accordion-panel" data-accordion-panel>
									<p class="max-w-3xl pb-6 text-base leading-relaxed text-base-700">{faq.answer}</p>
								</div>
							</details>
						))
					}
				</div>
			</div>
		</section>

		<TestimonialQuote />
		<Contact class="mt-12" />
	</main>
</BaseLayout>

<style>
	.service-hero-reveal,
	.service-image-reveal {
		animation: service-enter 860ms var(--motion-ease-out) both;
		animation-delay: var(--service-enter-delay, 0ms);
	}

	.service-image-reveal {
		animation-duration: 980ms;
	}

	.service-image-frame {
		background: var(--color-base-100);
		isolation: isolate;
	}

	.service-image {
		transform: scale(1.01);
		transition:
			filter 900ms var(--motion-ease-out),
			transform 1100ms var(--motion-ease-out);
		will-change: transform;
	}

	.service-image-frame:hover .service-image {
		filter: saturate(1.04) contrast(1.02);
		transform: scale(1.035);
	}

	.service-highlight-card {
		transition:
			background-color var(--motion-duration-base) var(--motion-ease-out),
			border-color var(--motion-duration-base) var(--motion-ease-out),
			box-shadow var(--motion-duration-base) var(--motion-ease-out),
			transform var(--motion-duration-base) var(--motion-ease-out);
	}

	.service-highlight-card:hover,
	.service-highlight-card:focus-within {
		border-color: color-mix(in srgb, var(--color-primary-500) 45%, var(--color-primary-200));
		background-color: color-mix(in srgb, var(--color-base-50) 88%, white);
		box-shadow: 0 1.25rem 3rem rgb(67 54 45 / 0.08);
		transform: translateY(-0.25rem);
	}

	.service-copy-block {
		position: relative;
	}

	.service-copy-block::before {
		position: absolute;
		top: 0.35rem;
		left: -1.25rem;
		width: 1px;
		height: calc(100% - 0.35rem);
		background: linear-gradient(
			to bottom,
			color-mix(in srgb, var(--color-primary-400) 55%, transparent),
			transparent
		);
		content: "";
		opacity: 0;
		transform: scaleY(0.4);
		transform-origin: top;
		transition:
			opacity 700ms var(--motion-ease-out),
			transform 900ms var(--motion-ease-out);
	}

	.js-anim .service-copy-block.is-visible::before {
		opacity: 1;
		transform: scaleY(1);
	}

	.service-next-link {
		background-color: transparent;
		transition:
			background-color var(--motion-duration-base) var(--motion-ease-out),
			border-color var(--motion-duration-base) var(--motion-ease-out),
			color var(--motion-duration-base) var(--motion-ease-out),
			transform var(--motion-duration-base) var(--motion-ease-out);
	}

	.service-next-link:hover,
	.service-next-link:focus-visible {
		background-color: color-mix(in srgb, var(--color-base-50) 72%, white);
		transform: translateY(-0.125rem);
	}

	@keyframes service-enter {
		from {
			opacity: 0;
			transform: translateY(1.35rem);
		}

		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.service-accordion summary::-webkit-details-marker {
		display: none;
	}

	.accordion-icon {
		position: relative;
		display: inline-grid;
		width: 1rem;
		height: 1rem;
		flex: 0 0 1rem;
		place-items: center;
		color: var(--color-primary-600);
		transition:
			color var(--motion-duration-fast) var(--motion-ease-out),
			transform var(--motion-duration-base) var(--motion-ease-out);
	}

	.service-accordion summary:hover .accordion-icon {
		color: var(--color-primary-800);
	}

	.accordion-icon__line {
		position: absolute;
		width: 1rem;
		height: 1px;
		background: currentColor;
		transition:
			opacity var(--motion-duration-fast) var(--motion-ease-out),
			transform var(--motion-duration-base) var(--motion-ease-out);
	}

	.accordion-icon__line--vertical {
		transform: rotate(90deg);
	}

	.service-accordion[open]:not([data-closing="true"]) .accordion-icon {
		color: var(--color-primary-800);
		transform: rotate(180deg);
	}

	.service-accordion[open]:not([data-closing="true"]) .accordion-icon__line--vertical {
		opacity: 0;
		transform: rotate(90deg) scaleX(0.35);
	}

	.accordion-panel {
		overflow: hidden;
		height: 0;
		opacity: 0;
		transform: translateY(-0.25rem);
		transition:
			height 320ms var(--motion-ease-out),
			opacity var(--motion-duration-base) var(--motion-ease-out),
			transform 320ms var(--motion-ease-out);
	}

	.service-accordion[open] .accordion-panel {
		height: auto;
	}

	.service-accordion[open]:not([data-closing="true"]) .accordion-panel {
		opacity: 1;
		transform: translateY(0);
	}

	@media (prefers-reduced-motion: reduce) {
		.service-hero-reveal,
		.service-image-reveal {
			animation: none;
		}

		.service-image,
		.service-highlight-card,
		.service-copy-block::before,
		.service-next-link,
		.accordion-icon,
		.accordion-icon__line,
		.accordion-panel {
			transition: none;
		}

		.service-image,
		.service-image-frame:hover .service-image,
		.service-highlight-card:hover,
		.service-highlight-card:focus-within,
		.service-copy-block::before,
		.service-next-link:hover,
		.service-next-link:focus-visible {
			transform: none;
		}
	}
</style>
