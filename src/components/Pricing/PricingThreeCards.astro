---
/**
 * * Pricing cards with three cards
 */

import Button from "@components/Button/Button.astro";
import { Image } from "astro:assets";

interface pricingItem {
	name: string;
	duration: string;
	featured?: boolean;
	price: string;
	description: string;
	features: string[];
	image: ImageMetadata;
}

import image2 from "@assets/images/family-images/familyphotography_2.jpg";
import image3 from "@assets/images/family-images/familyphotography_7.jpeg";
import image1 from "@assets/images/newborn-images/newbornphotography_4.jpg";

const pricingData: pricingItem[] = [
	{
		name: "Motherhood",
		duration: "45 minutes",
		featured: false,
		price: "£200",
		description:
			"A session celebrating a mother's love — capturing the tender connection between you and your child in your home or a location of your choice.",
		features: [
			"Up to 3 children",
			"10 final hand-edited photos",
			"Private online gallery",
			"Upgrade to full gallery available (+£195)",
		],
		image: image3,
	},
	{
		name: "Newborn & Baby",
		duration: "up to 2 hours",
		featured: true,
		price: "£395",
		description:
			"Relaxed, baby-led sessions in your home capturing your beautiful new world — the tiny details, the exhaustion, and the absolute love.",
		features: [
			"Home-based, baby-led session",
			"Online gallery of hand-edited photos",
			"All final photos included",
			"10% discount on 6-month milestone follow-up",
		],
		image: image1,
	},
	{
		name: "Family",
		duration: "60–90 minutes",
		featured: false,
		price: "£250",
		description:
			"Honest, real, authentic family photographs capturing the magic in the ordinary. Tailored to your family at a location or home of your choosing.",
		features: [
			"10 final hand-edited photos",
			"Private online gallery",
			"Upgrade to full gallery available (+£195)",
		],
		image: image2,
	},
];
---

<section id="pricing" class="pricing-section scroll-mt-10 px-4 py-16 md:py-24">
	<div class="mx-auto max-w-6xl">
		<div class="mb-16 text-center" data-animate>
			<p class="hours-label text-primary-500 mb-3 tracking-[0.25em] uppercase">Investment</p>
			<h2 class="font-heading-1 text-4xl font-light tracking-wide md:text-5xl">
				Family & Newborn Packages
			</h2>
			<div class="bg-primary-300 mx-auto mt-6 h-px w-16"></div>
		</div>

		<div
			class="cards-grid mx-auto grid w-full max-w-md gap-8 sm:max-w-none sm:grid-cols-2 lg:grid-cols-3 lg:items-start lg:gap-6"
			data-animate-stagger
		>
			{
				pricingData.map((plan) => (
					<div
						class:list={[
							"pricing-card flex flex-col",
							plan.featured ? "pricing-card--featured" : "pricing-card--standard",
						]}
					>
						<div class="card-image-wrap overflow-hidden">
							<Image
								src={plan.image}
								alt={plan.name}
								width={500}
								densities={[1.5, 2]}
								class="card-image h-full w-full object-cover"
							/>
						</div>

						<div class="card-body flex flex-1 flex-col">
							<p class="hours-label text-primary-500 mb-2 text-xs tracking-[0.2em] uppercase">
								{plan.duration}
							</p>

							<h3 class="font-heading-1 text-2xl font-normal tracking-wide">{plan.name}</h3>

							<div class="bg-primary-200 my-5 h-px" />

							<p class="price-text font-decorative text-primary-700 text-3xl leading-tight tracking-wide">
								{plan.price}
							</p>

							<div class="bg-primary-200 my-5 h-px" />

							<p class="text-base-600 font-sans text-base leading-relaxed">{plan.description}</p>

							{plan.features.length > 0 && (
								<ul class="mt-5 flex flex-col gap-3">
									{plan.features.map((feature) => (
										<li class="text-base-600 flex items-start gap-3 font-sans text-sm leading-relaxed">
											<span class="bg-primary-400 mt-1.5 h-1 w-1 shrink-0 rounded-full" />
											{feature}
										</li>
									))}
								</ul>
							)}
						</div>
					</div>
				))
			}
		</div>

		<div class="services-bridge mt-16" data-animate>
			<div class="services-bridge__copy">
				<p class="hours-label text-primary-500 mb-3 tracking-[0.25em] uppercase">
					Also photographing
				</p>
				<h3
					class="font-heading-1 text-primary-700 text-3xl leading-tight font-light tracking-wide md:text-4xl"
				>
					Weddings, families, newborns, and the stories in between
				</h3>
				<p class="text-base-600 mt-5 max-w-2xl font-sans text-base leading-relaxed md:text-lg">
					If you are planning something a little different, Brook also photographs wedding
					days and family stories across Chichester, West Sussex, London, and beyond.
				</p>
			</div>
			<div class="services-bridge__actions">
				<Button href="/#contact" variant="primary" arrow="right" class="services-bridge__button">
					Enquire about a family session
				</Button>
				<Button
					href="/wedding-photographer-chichester/"
					variant="outline"
					arrow="right"
					class="services-bridge__button services-bridge__button--secondary"
				>
					View wedding photography
				</Button>
			</div>
		</div>
	</div>
</section>

<style>
	.pricing-section {
		background-color: oklch(97.46% 0.0051 67.76); /* primary-50 */
	}

	.services-bridge {
		display: grid;
		grid-template-columns: minmax(0, 1.45fr) minmax(17rem, 0.55fr);
		gap: clamp(2rem, 5vw, 4rem);
		align-items: center;
		padding: clamp(2rem, 5vw, 3.5rem);
		background:
			linear-gradient(135deg, oklch(100% 0 0 / 0.9), oklch(96.72% 0.011 78.21 / 0.92)),
			oklch(99% 0.004 76);
		border: 1px solid oklch(88.03% 0.0219 76.52);
		box-shadow: 0 18px 60px -40px oklch(45.03% 0.0426 44.25 / 0.45);
	}

	.services-bridge__copy {
		position: relative;
	}

	.services-bridge__copy::after {
		content: "";
		display: block;
		width: 4rem;
		height: 1px;
		margin-top: 1.75rem;
		background-color: oklch(80.1% 0.0376 73.97);
	}

	.services-bridge__actions {
		display: flex;
		flex-direction: column;
		gap: 0.875rem;
		align-items: stretch;
		justify-content: center;
	}

	:global(.services-bridge__button) {
		justify-content: center;
		padding: 0.9rem 1.25rem;
		text-align: center;
	}

	:global(.services-bridge__button--secondary) {
		background-color: oklch(100% 0 0 / 0.45);
	}

	.pricing-card {
		transition:
			box-shadow var(--motion-duration-base) var(--motion-ease-out),
			transform var(--motion-duration-base) var(--motion-ease-out);
		will-change: transform;
	}

	.pricing-card:hover {
		transform: translateY(-4px);
	}

	/* Standard card */
	.pricing-card--standard {
		background-color: white;
	}

	.pricing-card--standard .card-image-wrap {
		aspect-ratio: 4 / 3;
	}

	.pricing-card--standard .card-body {
		padding: 2rem 1.75rem 2.25rem;
		border: 1px solid oklch(88.03% 0.0219 76.52); /* primary-200 */
		border-top: none;
	}

	/* Featured card */
	.pricing-card--featured {
		background-color: white;
		box-shadow: 0 8px 40px -8px oklch(64.12% 0.0623 60.4 / 0.2);
		position: relative;
	}

	.pricing-card--featured:hover {
		box-shadow: 0 16px 48px -14px oklch(64.12% 0.0623 60.4 / 0.32);
	}

	.pricing-card--featured::before {
		content: "Most Popular";
		position: absolute;
		top: 1rem;
		right: 1rem;
		z-index: 10;
		font-family: var(--font-sans);
		font-size: 0.65rem;
		letter-spacing: 0.15em;
		text-transform: uppercase;
		background-color: oklch(88.03% 0.0219 76.52);
		color: oklch(45.03% 0.0426 44.25);
		padding: 0.35rem 0.75rem;
	}

	.pricing-card--featured .card-image-wrap {
		aspect-ratio: 3 / 4;
	}

	.pricing-card--featured .card-body {
		padding: 2.25rem 2rem 2.5rem;
		border: 1px solid oklch(80.1% 0.0376 73.97); /* primary-300 */
		border-top: none;
	}

	.pricing-card--featured .price-text {
		font-size: 2.25rem;
	}

	/* Image zoom on hover */
	.card-image-wrap {
		overflow: hidden;
	}

	.card-image {
		transition:
			filter var(--motion-duration-slow) var(--motion-ease-out),
			transform var(--motion-duration-slow) var(--motion-ease-out);
	}

	.pricing-card:hover .card-image {
		filter: saturate(1.03) contrast(1.02);
		transform: scale(1.03);
	}

	/* On large screens, featured card sits slightly higher */
	@media (min-width: 1024px) {
		.pricing-card--featured {
			margin-top: -1.5rem;
		}
	}

	@media (max-width: 767px) {
		.services-bridge {
			grid-template-columns: 1fr;
			padding: 1.75rem;
		}

		.services-bridge__copy::after {
			margin-top: 1.25rem;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.pricing-card,
		.card-image {
			transition: none;
			transform: none !important;
		}
	}
</style>
