---
/**
 * * Hero with background image
 * You'll want a mobile image, and a desktop image for this.
 */

import heroImage from "@assets/images/newborn-images/newbornphotography_22.jpeg";
import Button from "@components/Button/Button.astro";
import { Image } from "astro:assets";
---

<section id="hero" class="relative z-10 flex min-h-[100lvh] w-full">
	<!-- background image -->
	<div class="hero-media absolute -z-10 h-full min-h-full w-full overflow-hidden">
		<div class="hero-overlay absolute inset-0 bg-black/40"></div>

		<Image
			src={heroImage}
			class="hero-image h-full w-full object-cover [object-position:35%_center] md:object-center"
			alt="family"
			aria-hidden="true"
			loading="eager"
			height={1400}
		/>
	</div>

	<!-- hero items -->
	<div class="site-container relative w-full gap-10 py-44 text-center md:py-52 md:text-left">
		<!-- Hero text -->
		<div class="text-base-50 my-auto mr-auto max-w-[800px] flex-col">
			<h1
				class="hero-copy font-heading-1 text-4xl font-semibold text-pretty drop-shadow-[0_2px_8px_rgba(0,0,0,0.6)] md:text-7xl md:leading-tight"
			>
				Relaxed, natural photography for your family's most precious moments
			</h1>
			<p
				class="hero-copy mt-8 text-lg tracking-widest text-pretty drop-shadow-[0_1px_4px_rgba(0,0,0,0.5)] md:max-w-[550px] md:text-2xl"
				style="--hero-delay: 170ms"
			>
				Come as you are. Capturing authentic, timeless memories of your family and new arrivals.
			</p>
			<div class="hero-copy mt-10 flex flex-wrap justify-center gap-4 md:justify-start" style="--hero-delay: 320ms">
				<Button
					variant="primary"
					arrow="right"
					href="/#contact"
					class="px-6 py-3 text-lg shadow-[0_0.75rem_1.75rem_rgba(0,0,0,0.18)] md:px-7 md:py-3.5 md:text-xl"
				>
					Get a Quote
				</Button>
			</div>
		</div>
	</div>
</section>

<style>
	.hero-image {
		animation: heroImageSettle 1600ms var(--motion-ease-emphatic) both;
		will-change: transform;
	}

	.hero-overlay {
		animation: heroOverlayFade 900ms var(--motion-ease-out) both;
	}

	.hero-copy {
		animation: heroCopyReveal 780ms var(--motion-ease-out) both;
		animation-delay: var(--hero-delay, 0ms);
		will-change: opacity, transform;
	}

	@keyframes heroImageSettle {
		from {
			transform: scale(1.045);
		}

		to {
			transform: scale(1);
		}
	}

	@keyframes heroOverlayFade {
		from {
			opacity: 0;
		}

		to {
			opacity: 1;
		}
	}

	@keyframes heroCopyReveal {
		from {
			opacity: 0;
			transform: translateY(24px);
		}

		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.hero-image,
		.hero-overlay,
		.hero-copy {
			animation: none;
			transform: none;
			opacity: 1;
		}
	}
</style>
