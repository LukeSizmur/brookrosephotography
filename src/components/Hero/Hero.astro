---
/**
 * * Hero with background image
 * You'll want a mobile image, and a desktop image for this.
 */

import Button from "@components/Button/Button.astro";
import heroImage from "@assets/images/newborn-images/newbornphotography_22.jpeg";
import { Image } from "astro:assets";
---

<section id="hero" class="relative z-10 flex min-h-[100lvh] w-full">
	<!-- background image -->
	<div class="absolute -z-10 h-full min-h-full w-full overflow-hidden">
		<div class="absolute inset-0 bg-black/40"></div>

		<Image
			src={heroImage}
			class="h-full w-full object-cover [object-position:35%_center] md:object-center"
			alt="family"
			aria-hidden="true"
			loading="eager"
			height={1400}
		/>
	</div>

	<!-- hero items -->
	<div class="site-container relative w-full gap-10 py-44 text-center md:py-52 md:text-left">
		<!-- Hero text -->
		<div class="text-base-50 my-auto mr-auto max-w-[800px] flex-col">
			<h1
				class="font-heading-1 text-4xl font-semibold text-pretty drop-shadow-[0_2px_8px_rgba(0,0,0,0.6)] md:text-7xl md:leading-tight"
			>
				Relaxed, natural photography for your family's most precious moments
			</h1>
			<p
				class="mt-8 text-lg tracking-widest text-pretty drop-shadow-[0_1px_4px_rgba(0,0,0,0.5)] md:max-w-[550px] md:text-2xl"
			>
				Come as you are. Capturing authentic, timeless memories of your family and new arrivals.
			</p>
			<div class="mt-10 flex flex-wrap justify-center gap-4 md:justify-start">
				<Button
					variant="ghost"
					arrow="right"
					href="/#contact"
					class="pl-0 text-xl text-white drop-shadow-[0_1px_1px_rgba(0,0,0,0.2)] md:text-3xl"
				>
					Get a Quote
				</Button>
			</div>
		</div>
	</div>
</section>
