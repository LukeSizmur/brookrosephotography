---
import SiteLogo from "@components/SiteLogo/SiteLogo.astro";
import siteData from "@config/siteData.json";
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";

import FooterLink from "./FooterLink.astro";
import footerImage from "@assets/images/footer-image.png";

const today = new Date();
---

<footer class="relative z-10 mt-12 overflow-hidden py-16">

	<!-- background image + overlay -->
	<div class="absolute -z-10 h-full min-h-full w-full overflow-hidden">
		<div class="absolute inset-0 bg-black/10"></div>
		<Image
			src={footerImage}
			alt=""
			aria-hidden="true"
			width={2400}
			densities={[1.5, 2]}
			class="h-auto min-h-full w-full object-cover object-bottom"
			loading="eager"
		/>
	</div>

	<div class="site-container flex flex-col items-center gap-8 mt-10">

		<!-- logo -->
		<SiteLogo />

		<!-- nav links -->
		<nav class="flex flex-wrap justify-center gap-x-8 gap-y-2 text-sm tracking-widest uppercase">
			<FooterLink href="/">Home</FooterLink>
			<FooterLink href="/#portfolio">Portfolio</FooterLink>
			<FooterLink href="/#pricing">Pricing</FooterLink>
			<FooterLink href="/#contact">Contact</FooterLink>
		</nav>

		<!-- tagline -->
		<p class="max-w-xs text-center text-sm leading-relaxed text-black/80">
			<span class="italic">Lets connect!</span> Follow along to see more photography and get inspired.
		</p>

		<!-- socials -->
		<div class="flex items-center gap-5 text-black/80">
			<a href="https://www.facebook.com/Brookrosephotography/" target="_blank" rel="noopener noreferrer">
				<Icon name="socials/mdi-facebook" class="size-6 transition hover:opacity-80" />
				<span class="sr-only">Facebook</span>
			</a>
			<a href="https://www.instagram.com/brookrosephotography/" target="_blank" rel="noopener noreferrer">
				<Icon name="socials/basil-instagram-solid" class="size-6 transition hover:opacity-80" />
				<span class="sr-only">Instagram</span>
			</a>
			<a href="https://uk.pinterest.com/brookrosephotos/" target="_blank" rel="noopener noreferrer">
				<Icon name="socials/mdi-pintrest" class="size-[22px] transition hover:opacity-80" />
				<span class="sr-only">Pinterest</span>
			</a>
		</div>

		<!-- divider -->
		<div class="h-px w-16 bg-black/30"></div>

		<!-- copyright -->
		<p class="text-center text-xs tracking-widest text-black/60 uppercase">
			&copy; {today.getFullYear()} Brook Rose Photography
		</p>

	</div>
</footer>
