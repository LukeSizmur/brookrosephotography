---
/**
 * * These are small cards that are used in the portfolio section
 */
import Button from "@components/Button/Button.astro";
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";

interface Props {
	portfolio: CollectionEntry<"portfolios">;
	direction: "horizontal" | "vertical";
	noTransitions?: boolean;
}

const { portfolio, direction, noTransitions = false } = Astro.props as Props;
const { title, description, heroImage } = portfolio.data;
---

<div
	class:list={[
		"portfolio-card group grid gap-2 md:gap-4",
		{
			"md:grid-cols-2": direction === "horizontal",
		},
	]}
>
	<a href={`/portfolio/${portfolio.id}`} class="portfolio-card__image-link aspect-square overflow-hidden">
		{
			noTransitions && (
				<Image
					src={heroImage}
					alt={title}
					width={450}
					densities={[1.5, 2, 3]}
					class="portfolio-card__image h-full w-full object-cover"
				/>
			)
		}
		{
			!noTransitions && (
				<Image
					src={heroImage}
					alt={title}
					width={450}
					densities={[1.5, 2, 3]}
					class="portfolio-card__image h-full w-full object-cover"
					transition:name={`portfolio-image-${portfolio.id}`}
				/>
			)
		}
	</a>
	<div class="flex flex-col justify-between gap-2">
		<div>
			<h3 class="h3 text-primary-500 tracking-widest">{title}</h3>
			<p class="mt-4 lg:text-lg">{description}</p>
		</div>
		<div class="flex">
			<Button variant="ghost" arrow="right" href={`/portfolio/${portfolio.id}`} class="pl-0">
				View More
			</Button>
		</div>
	</div>
</div>

<style>
	.portfolio-card__image-link {
		display: block;
		background-color: var(--color-base-200);
	}

	.portfolio-card__image {
		transition:
			transform var(--motion-duration-slow) var(--motion-ease-out),
			filter var(--motion-duration-slow) var(--motion-ease-out);
		will-change: transform;
	}

	.portfolio-card:hover .portfolio-card__image,
	.portfolio-card:focus-within .portfolio-card__image {
		filter: saturate(1.03) contrast(1.02);
		transform: scale(1.035);
	}

	.portfolio-card h3,
	.portfolio-card p {
		transition:
			color var(--motion-duration-base) var(--motion-ease-out),
			transform var(--motion-duration-base) var(--motion-ease-out);
	}

	.portfolio-card:hover h3,
	.portfolio-card:focus-within h3 {
		transform: translateY(-1px);
	}

	@media (prefers-reduced-motion: reduce) {
		.portfolio-card__image,
		.portfolio-card h3,
		.portfolio-card p {
			transition: none;
			transform: none !important;
		}
	}
</style>
