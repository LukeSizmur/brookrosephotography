---
/**
 * * About section
 */

import profileImage from "@assets/images/photographer-min.jpg";
import { Image } from "astro:assets";
---

<section id="about" class="site-container scroll-mt-10 py-8 md:py-12">
	<div class="flex flex-col md:flex-row">
		<div class="md:w-2/3" data-animate="from-left">
			<h2 class="h3 text-primary-500 text-pretty uppercase">Meet your photographer</h2>
			<h3 class="mt-4 font-handwriting text-5xl font-normal">Brook</h3>
			<div class="bg-section-olive mt-8 p-8 md:mb-20 lg:text-lg">
				<p>
				I love adventures big and small, far away travels or more local,
		        long beach or forest walk with my babies and husband and our dog Poppy.
				I always have a trip in my mind planned and locations I would like to visit
				I want to explore as much as the world as possible with my family by my side.
				</p>
				<div class="flex w-3/4 justify-end">
					<p class="font-handwriting text-4xl">— Brook</p>
				</div>
			</div>
		</div>
		<div class="mr-auto max-w-md md:w-1/3 md:max-w-none" data-animate="from-right" style="--animate-delay: 150ms">
			<div class="my-auto aspect-[3/4] w-full overflow-hidden">
				<Image
					src={profileImage}
					alt="Brook"
					width={450}
					densities={[1.5, 2]}
					class="h-auto min-h-full w-full min-w-full object-cover"
				/>
			</div>
		</div>
	</div>
</section>
